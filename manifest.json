{
  "manifest_version": 3,
  "name": "BingeBlocker",
  "version": "1.2",

  "action": {
    "default_popup": "popup.html",
    "default_width": 400,
    "default_height": 500
  },

  "permissions": [
    "storage"
  ],

  "web_accessible_resources": [
    {
      "resources": ["imgs/notes-bg.jpg", "imgs/wa.svg"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}